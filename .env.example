PORT=3000
DATA_DIR=./data
# Origin the app is served from. Required by adapter-node so that form/upload
# POSTs pass CSRF protection. Set this to your Tailscale hostname in production.
ORIGIN=http://localhost:3000
# Max upload body size. adapter-node defaults to 512K — too small for a Mela
# library export. Accepts a byte count or K/M/G suffix; "Infinity" disables it.
BODY_SIZE_LIMIT=1G
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
